# ---------------------------------------------------------------------------
# Zoya — Desktop AI Assistant : environment configuration
# Copy this file to ".env" and adjust values as needed.
# All keys are read by pydantic-settings (case-insensitive).
# ---------------------------------------------------------------------------

# --- General application ---------------------------------------------------
APP_NAME=Zoya
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
LOG_DIR=logs
CONFIG_PATH=config/settings.yaml

# --- Automation behaviour --------------------------------------------------
# Master kill-switch. When false, the DesktopAutomation facade refuses to run.
AUTOMATION_ENABLED=true
# Dry-run mode: no real input is sent; tools log what they WOULD do.
# Great for demos / CI. Read-only tools (list, search, read) still execute.
AUTOMATION_DRY_RUN=false
# Failsafe flag (reserved for the mouse corner-abort feature of future modules).
AUTOMATION_FAILSAFE=true

# --- LLM configuration -----------------------------------------------------
# Obtain a key from Google AI Studio
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_API_VERSION=v1beta         # v1beta is the stable endpoint for gemini-2.5

# --- LLM transport / resilience -------------------------------------------
LLM_TIMEOUT=120                   # seconds per Gemini API call
LLM_RETRY_ATTEMPTS=4              # total attempts (incl. first) for 429 / 5xx
LLM_RETRY_BASE_DELAY=1.0          # seconds — first retry backoff
LLM_RETRY_MAX_DELAY=30.0          # seconds — upper bound on any retry delay
